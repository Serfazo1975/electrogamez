# ─── Base de datos ────────────────────────────────────────────────────────────
# SQLite para desarrollo local
DATABASE_URL="file:./dev.db"
# Para producción usar PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/electrogamez"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="CAMBIAR_POR_SECRET_SEGURO"

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-email@gmail.com"
SMTP_PASSWORD="tu-app-password"
EMAIL_FROM="ElectroGamez <contacto@electrogamez.cl>"

# ─── WhatsApp (Meta Cloud API) ────────────────────────────────────────────────
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# ─── URL pública del sitio (para links en emails/WhatsApp) ───────────────────
NEXT_PUBLIC_APP_URL="https://electrogamez.cl"
