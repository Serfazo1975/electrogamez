# ============================================================
# ElectroGamez - Variables de Entorno
# Copia este archivo como .env.local y completa los valores
# NUNCA subas .env.local al repositorio
# ============================================================

# --- Base de Datos ---
# Desarrollo local (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# Producción (PostgreSQL recomendado):
# DATABASE_URL="postgresql://usuario:contraseña@host:5432/electrogamez"

# --- NextAuth ---
# URL del sitio (cambiar en producción)
NEXTAUTH_URL="http://localhost:3000"
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=""

# --- Email / Notificaciones (opcional) ---
# Usar Resend (resend.com) o Gmail SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@tudominio.com"

# --- WhatsApp API (opcional) ---
# Meta Business API
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_ID=""
